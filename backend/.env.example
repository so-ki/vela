# Application
APP_NAME=Vela 出海法务平台
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database (SQLite for dev; use PostgreSQL in production)
DATABASE_URL=sqlite:///./data/vela.db

# Chroma vector store
CHROMA_PERSIST_DIR=./data/chroma

# LLM 润色（Step 8）— 任选其一，DeepSeek 优先
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# QWEN_API_KEY=sk-...
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus
# LLM_POLISH_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Auth (production: set ALLOW_OPEN_REGISTRATION=false)
ALLOW_OPEN_REGISTRATION=true
ALLOW_PASSWORD_LOGIN=true

# SSO (OpenID Connect) — optional
# SSO_ENABLED=true
# SSO_PROVIDER_NAME=企业 SSO
# SSO_ISSUER_URL=https://idp.example.com/realms/vela
# SSO_CLIENT_ID=vela-platform
# SSO_CLIENT_SECRET=replace-me
# SSO_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback
# SSO_DEFAULT_ROLE=legal

# Word export — law_school = 法学院法律研究意见书
EXPORT_TEMPLATE=law_school
EXPORT_ORG_NAME=Vela 出海法务台 · 法学院合规研究格式
EXPORT_ORG_DEPARTMENT=企业法务部 / 合规研究中心
EXPORT_RECIPIENT_LABEL=企业管理层 / 投资委员会
