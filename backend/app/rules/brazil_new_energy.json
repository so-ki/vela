  "checklist_items": [
    {
      "id": "LAB-001",
      "dimension": "labor",
      "title": "核查本地雇佣规模与 CLT 适用",
      "description": "若方案涉及在巴西雇佣本地员工，确认适用 CLT 劳动合同、岗位分类及雇佣合同模板。",
      "priority": "high",
      "always_include": false,
      "triggers": ["雇员", "就业", "岗位", "450", "工人", "员工", "hiring", "jobs"]
    },
    {
      "id": "LAB-002",
      "dimension": "labor",
      "title": "FGTS 及法定福利缴付安排",
      "description": "核实 FGTS（工龄保障基金）8% 缴付、13薪、年假及法定福利预算与外包/派遣边界。",
      "priority": "high",
      "always_include": false,
      "triggers": ["FGTS", "福利", "薪酬", "派遣", "雇员", "员工", "就业", "CLT"]
    },
    {
      "id": "LAB-003",
      "dimension": "labor",
      "title": "工会与集体谈判风险",
      "description": "评估投资所在地工会覆盖、集体谈判（CCT/ACT）义务及劳资风险预案。",
      "priority": "medium",
      "always_include": false,
      "triggers": ["工会", "坎皮纳斯", "制造", "雇员", "员工"]
    },
    {
      "id": "LAB-004",
      "dimension": "labor",
      "title": "外籍派驻人员工作许可",
      "description": "如存在中方技术或管理人员派驻，核查工作签证、社保双重覆盖及派遣合规。",
      "priority": "medium",
      "always_include": false,
      "triggers": ["外派", "派驻", "中方", "签证", "expatriate"]
    },
    {
      "id": "FOR-001",
      "dimension": "foreign_investment",
      "title": "外资在巴西投资设立路径",
      "description": "确认通过子公司、合资公司或其他实体在巴西投资的设立流程（CNPJ 注册、公司章程、外资申报）。",
      "priority": "high",
      "always_include": true,
      "triggers": ["外资", "子公司", "100%", "全资", "合资", "FDI", "投资", "设立"]
    },
    {
      "id": "FOR-002",
      "dimension": "foreign_investment",
      "title": "行业外资准入限制筛查",
      "description": "核查拟投资行业是否存在外资股比、本地成分、特许或备案要求（含新能源、制造、研发等）。",
      "priority": "high",
      "always_include": true,
      "triggers": ["外资", "准入", "限制", "行业", "电池", "客车", "光伏", "储能", "研发", "制造", "FDI"]
    },
    {
      "id": "FOR-003",
      "dimension": "foreign_investment",
      "title": "RDE/外汇及利润汇回",
      "description": "评估巴西中央银行等外资登记、资本汇入、利润汇出及合规报告义务。",
      "priority": "medium",
      "always_include": true,
      "triggers": ["投资", "汇回", "外汇"]
    },
    {
      "id": "FOR-005",
      "dimension": "foreign_investment",
      "title": "CADE 经营者集中申报筛查",
      "description": "若涉及并购、股权收购、合资控制或资产集中，评估是否须向 CADE（经济防御管理委员会）提交集中申报或备案。",
      "priority": "medium",
      "always_include": false,
      "triggers": ["并购", "收购", "合并", "CADE", "反垄断", "集中", "股权", "合资", "控制"]
    },
    {
      "id": "TAX-001",
      "dimension": "tax",
      "title": "联邦层企业所得税（IRPJ/CSLL）",
      "description": "确认项目在巴西开展经营活动时的联邦所得税、社会贡献税适用及预估税负框架。",
      "priority": "high",
      "always_include": true,
      "triggers": ["所得税", "税", "经营", "研发", "制造", "投资"]
    },
    {
      "id": "TAX-002",
      "dimension": "tax",
      "title": "圣保罗州 ICMS 及州激励",
      "description": "核查圣保罗州 ICMS 及州级投资激励（Pró-Informática、Pró-Veículo 等；注意 PRODEIC 属马托格罗索州，非圣保罗）。参阅 InvestSP 与 Sefaz-SP 官方优惠清单。",
      "priority": "high",
      "always_include": true,
      "triggers": ["圣保罗", "坎皮纳斯", "州", "ICMS", "巴西", "投资"]
    },
    {
      "id": "TAX-003",
      "dimension": "tax",
      "title": "市级 ISS/IPTU 及地方税",
      "description": "确认投资所在城市的 ISS（服务环节）、IPTU 及市政收费义务。",
      "priority": "medium",
      "always_include": false,
      "triggers": ["坎皮纳斯", "市", "研发", "服务", "圣保罗"]
    },
    {
      "id": "TAX-004",
      "dimension": "tax",
      "title": "进口设备与零部件关税规划",
      "description": "评估生产线设备、电池材料进口关税、Ex Tarifário 及本地化采购对税负影响。",
      "priority": "medium",
      "always_include": false,
      "triggers": ["进口", "零部件", "设备", "电池", "组装"]
    },
    {
      "id": "IND-001",
      "dimension": "industry_access",
      "title": "工业用地与建设许可（Alvará）",
      "description": "若涉及新建厂房或改扩建，核查项目所在城市的用地规划（Zoneamento/Uso do Solo）、Alvará de Funcionamento 及消防 ocupação 合规（通过 city/state 参数 + 巴西 Connector 拉取市政指引）。",
      "priority": "high",
      "always_include": false,
      "triggers": ["厂房", "平方米", "m²", "建设", "开工", "设厂", "工厂", "greenfield"]
    },
    {
      "id": "IND-002",
      "dimension": "industry_access",
      "title": "制造业登记与运营许可",
      "description": "若涉及制造或组装业务，确认工业登记、产品认证（如 INMETRO/ANATEL）及运营许可路径。",
      "priority": "high",
      "always_include": false,
      "triggers": ["制造", "组装", "电池", "客车", "生产"]
    },
    {
      "id": "IND-003",
      "dimension": "industry_access",
      "title": "产线电气与机械安全（NR-10/NR-12）",
      "description": "制造产线须落实 NR-10 电气安全、NR-12 机械设备安全、操作培训及第三方检测安排。",
      "priority": "high",
      "always_include": false,
      "triggers": ["电池", "磷酸铁锂", "防火", "安全", "回收"]
    },
    {
      "id": "IND-004",
      "dimension": "industry_access",
      "title": "研发中心设立与业务许可",
      "description": "光伏、智能电网、LED 研发中心的设立登记、知识产权归属及与制造业务的分拆合规。",
      "priority": "medium",
      "always_include": false,
      "triggers": ["研发", "光伏", "智能电网", "LED", "研发中心"]
    },
    {
      "id": "IND-005",
      "dimension": "industry_access",
      "title": "产能扩张与分期投产合规",
      "description": "首年 1000 台客车及电池产能分期投产时，各阶段许可范围与扩产备案要求。",
      "priority": "medium",
