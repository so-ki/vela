# Production environment — copy to .env.prod and fill secrets before deploy

APP_ENV=production
DEBUG=false
SECRET_KEY=replace-with-openssl-rand-hex-32
POSTGRES_PASSWORD=replace-with-strong-password

# Public URL (no trailing slash) — used for CORS, SSO redirect, frontend links
PUBLIC_URL=https://vela.example.com
HTTP_PORT=8080

# Auth
ALLOW_OPEN_REGISTRATION=false
ALLOW_PASSWORD_LOGIN=true

# SSO (OpenID Connect) — Keycloak / Azure AD / Okta compatible
SSO_ENABLED=false
SSO_PROVIDER_NAME=企业 SSO
SSO_ISSUER_URL=https://idp.example.com/realms/vela
SSO_CLIENT_ID=vela-platform
SSO_CLIENT_SECRET=replace-me
SSO_REDIRECT_URI=https://vela.example.com/api/v1/auth/sso/callback
SSO_DEFAULT_ROLE=legal

# Word export — law_school = 法学院标准法律研究意见书
EXPORT_TEMPLATE=law_school
EXPORT_ORG_NAME=某某大学法学院 · 企业合规研究中心
EXPORT_ORG_DEPARTMENT=涉外投资合规研究项目组
EXPORT_RECIPIENT_LABEL=企业管理层 / 投资委员会

# Optional LLM
LLM_POLISH_ENABLED=false
QWEN_API_KEY=
